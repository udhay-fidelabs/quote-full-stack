{
  "name": "backend-express",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --watch ./src/index.ts",
    "build": "tsc -b",
    "start": "bun run ./src/index.ts",
    "prebuild": "cd ../frontend && bun run build",
    "postinstall": "bun run build",
    "test": "NODE_ENV=development vitest run",
    "test:watch": "NODE_ENV=development vitest",
    "test:coverage": "NODE_ENV=development vitest run --coverage",
    "test:e2e": "playwright test",
    "seed:plans": "bun run ./src/scripts/seed-plans.ts",
    "lint": "biome lint ./src",
    "format": "biome format --write ./src",
    "check": "biome check --write ./src"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.58.2",
    "@types/bun": "latest",
    "@types/express-rate-limit": "^6.0.2",
    "@types/multer": "^2.0.0",
    "@types/multer-s3": "^3.0.3",
    "@types/nodemailer": "^7.0.9",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "mongodb-memory-server": "^10.1.3",
    "multer": "^2.1.0",
    "supertest": "^7.0.0",
    "tsconfig-paths": "^4.2.0",
    "vitest": "^4.0.18"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1003.0",
    "@aws-sdk/s3-request-presigner": "^3.1003.0",
    "@ngrok/ngrok": "^1.7.0",
    "@shopify/shopify-api": "^12.3.0",
    "@shopify/shopify-app-express": "^6.0.5",
    "@shopify/shopify-app-session-storage-mongodb": "^5.0.5",
    "@types/express": "^5.0.6",
    "cloudinary": "^2.9.0",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "inversify": "^7.11.0",
    "mongoose": "^9.1.5",
    "multer-s3": "^3.0.1",
    "nodemailer": "^7.0.13",
    "reflect-metadata": "^0.2.2",
    "zod": "^4.3.6"
  }
}