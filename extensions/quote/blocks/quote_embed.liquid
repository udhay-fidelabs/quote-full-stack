{% schema %}
{
  "name": "Global Quote Embed",
  "target": "body",
  "settings": []
}
{% endschema %}

{% assign config = shop.metafields.merchant_quote.config.value %}
{% assign app_enabled = config.appEnabled | default: false %}

{% if app_enabled %}
  {% comment %} 1. Initial Visibility Check (Customer) {% endcomment %}
  {% assign show_by_visibility = true %}
  {% if config.visibility == 'logged_in' and customer == null %}
    {% assign show_by_visibility = false %}
  {% endif %}

  {% comment %} 2. Product Targeting Logic {% endcomment %}
  {% if show_by_visibility and product %}
    {% if config.displayCondition == 'products' %}
      {% assign product_id_str = product.id | append: "" %}
      {% assign found = false %}
      {% for pid in config.selectedProducts %}
         {% if pid contains product_id_str %}
            {% assign found = true %}
         {% endif %}
      {% endfor %}
      {% unless found %}{% assign show_by_visibility = false %}{% endunless %}
      
    {% elsif config.displayCondition == 'collections' %}
      {% assign found = false %}
      {% if product.collections.size > 0 %}
        {% for collection in product.collections %}
          {% assign current_coll_gid = 'gid://shopify/Collection/' | append: collection.id %}
          {% for scid in config.selectedCollections %}
            {% if scid == current_coll_gid %}
              {% assign found = true %}
              {% break %}
            {% endif %}
          {% endfor %}
          {% if found %}{% break %}{% endif %}
        {% endfor %}
      {% endif %}
      {% unless found %}{% assign show_by_visibility = false %}{% endunless %}

    {% elsif config.displayCondition == 'custom' %}
      {% assign found = false %}
      {% for tag in product.tags %}
         {% for target_tag in config.productTags %}
            {% if tag == target_tag %}
               {% assign found = true %}
            {% endif %}
         {% endfor %}
      {% endfor %}
      {% unless found %}{% assign show_by_visibility = false %}{% endunless %}
    {% endif %}
  {% endif %}

  {% assign hide_content_for_guests = false %}
  {% if customer == null %}
    {% assign hide_content_for_guests = true %}
  {% endif %}

  <script id="mq-global-config">
    window.rqGlobalSettings = {
      appEnabled: {{ config.appEnabled | default: false | json }},
      shouldShow: {{ show_by_visibility | json }},
      displayCondition: {{ config.displayCondition | default: "all" | json }},
      selectedCollections: {{ config.selectedCollections | default: "[]" | json }},
      productCollectionGids: [{% for c in product.collections %}"gid://shopify/Collection/{{c.id}}"{% unless forloop.last %},{% endunless %}{% endfor %}],
      {% assign current_btn_text = config.buttonText %}
      {% if config.buttonText == nil %}{% assign current_btn_text = "Request Quote" %}{% endif %}
      buttonText: {{ current_btn_text | json }},
      {% assign current_btn_color = config.buttonColor %}
      {% if config.buttonColor == nil %}{% assign current_btn_color = "#008060" %}{% endif %}
      buttonColor: {{ current_btn_color | json }},
      {% assign current_text_color = config.buttonTextColor %}
      {% if config.buttonTextColor == nil %}{% assign current_text_color = "#FFFFFF" %}{% endif %}
      buttonTextColor: {{ current_text_color | json }},
      hideAddToCart: {{ config.hideAddToCart | default: false | json }},
      hideBuyNow: {{ config.hideBuyNow | default: false | json }},
      hidePriceGlobal: {{ config.hidePriceGlobal | default: false | json }},
      loginToSeePrice: {% if config.loginToSeePrice and hide_content_for_guests %}true{% else %}false{% endif %},
      placementLocation: {{ config.placementLocation | default: "above" | json }},
      visibility: {{ config.visibility | default: "all" | json }},
      showSku: {{ config.showSku | default: false | json }},
      showVendor: {{ config.showVendor | default: false | json }},
      showQuantity: {{ config.showQuantity | default: true | json }},
      showProductNote: {{ config.showProductNote | default: false | json }}
    };
  </script>

  {% comment %} 3. Conditional Hiding Styles {% endcomment %}
  {% if show_by_visibility %}
    <style id="mq-hiding-logic">
      {% if config.hideAddToCart %}
        [name="add"], .product-form__submit, .add-to-cart, .btn--add-to-cart, .purchase-details__buttons button,
        .quantity, .product-form__input--quantity, .product-form__item--quantity, [name="quantity"], .qty-wrapper, .product-form__quantity,
        .quantity-selector-wrapper, quantity-selector-component, .quantity-selector, .quantity__input {
          display: none !important; margin: 0 !important; visibility: hidden !important; height: 0 !important; overflow: hidden !important; opacity: 0 !important; pointer-events: none !important; padding: 0 !important;
        }
      {% endif %}
      {% if config.hideBuyNow %}
        .shopify-payment-button, .payment-buttons, .shopify-payment-button__button--unbranded, .dynamic-checkout__buttons {
          display: none !important; margin: 0 !important; visibility: hidden !important; height: 0 !important; overflow: hidden !important; opacity: 0 !important; pointer-events: none !important;
        }
      {% endif %}
      {% if config.hidePriceGlobal %}
        .price, .product-price, .product__price, .product-single__price, .price-item, .product__tax {
          display: none !important; margin: 0 !important; visibility: hidden !important; height: 0 !important; overflow: hidden !important; opacity: 0 !important; pointer-events: none !important; padding: 0 !important;
        }
      {% elsif config.loginToSeePrice %}
        {% if customer == null %}
          .price, .product-price, .product__price, .product-single__price, .price-item, .product__tax {
            display: none !important; margin: 0 !important; visibility: hidden !important; height: 0 !important; overflow: hidden !important; opacity: 0 !important; pointer-events: none !important; padding: 0 !important;
          }
        {% endif %}
      {% endif %}
    </style>
  {% endif %}

  {% comment %} 3. Custom CSS Overrides (if any) {% endcomment %}
  <style id="mq-custom-colors">
    /* Global variables for consistent styling across blocks */
    :root {
      --mq-primary-color: {{ config.buttonColor | default: "#008060" }};
      --mq-text-color: {{ config.buttonTextColor | default: "#FFFFFF" }};
    }
  </style>

  {{ 'request-quote.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'rq-validation.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'rq-api.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'rq-cart.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'rq-ui.js' | asset_url }}" defer="defer"></script>
  <script src="{{ 'request-quote.js' | asset_url }}" defer="defer"></script>

  {% render 'request-quote-form-ui', block_id: 'global' %}
  {% render 'quote-cart-drawer' %}
{% endif %}
