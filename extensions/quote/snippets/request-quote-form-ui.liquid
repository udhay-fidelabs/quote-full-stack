{% # theme-check-disable OrphanedSnippet %}
{%- assign block_id = block_id | default: 'global' -%}
<div id="rqModal-{{ block_id }}" class="rq-modal" aria-hidden="true" role="dialog">
  <div id="rq-app-root-{{ block_id }}" data-shop="{{ shop.permanent_domain }}" style="display:none;"></div>
  <div class="rq-modal-overlay" onclick="rqCloseModal('{{ block_id }}')"></div>
  <div class="rq-modal-content">
    <button class="rq-modal-close" onclick="rqCloseModal('{{ block_id }}')" aria-label="Close Modal">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        <path d="M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <div class="rq-form-container" id="rq-form-container-{{ block_id }}">
      {%- assign config = shop.metafields.merchant_quote.config.value -%}

      <!-- LEFT COLUMN: Cart Summary -->
      <div class="rq-column-left">
        <div class="rq-column-header">
          <h3 style="font-size: 18px; font-weight: 700; margin-bottom: 12px; color: var(--rq-text);">
            Your Quote Cart
          </h3>
        </div>

        <div id="rq-cart-items-list-{{ block_id }}">
          <!-- Items will be injected here by JS -->
        </div>

      </div>

      <!-- RIGHT COLUMN: The Form -->
      <div class="rq-column-right">
        <button class="rq-modal-close-internal" onclick="rqCloseModal('{{ block_id }}')" aria-label="Close Modal">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M18 6L6 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            <path d="M6 6L18 18" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>

        <div class="rq-form-header" style="text-align: left; margin-bottom: 16px;">
          <h2
            id="rq-form-title-{{ block_id }}"
            style="font-size: 22px; margin-bottom: 2px; text-align: left; background: none; -webkit-text-fill-color: initial;"
          >
            {{ config.title | default: 'Request Your Quote' }}
          </h2>
          <p id="rq-form-desc-{{ block_id }}" style="text-align: left;">
            {{ config.description | default: "Fill in your details and we'll get back to you shortly" }}
          </p>
        </div>

        <form id="rq-form-{{ block_id }}" onsubmit="event.preventDefault();" class="rq-form rq-single-page-form">
          <input type="hidden" name="productId" value="{{ product.id }}">
          <input type="hidden" name="handle" value="{{ product.handle }}">
          <input type="hidden" name="variantId" value="{{ product.selected_or_first_available_variant.id }}">
          <input type="hidden" name="productTitle" value="{{ product.title }}">
          <input type="hidden" name="variantTitle" value="{{ product.selected_or_first_available_variant.title }}">
          <input type="hidden" name="productUrl" value="{{ shop.url }}{{ product.url }}">
          <input
            type="hidden"
            name="productImage"
            value="{% if product.featured_image %}{{ product.featured_image | image_url: width: 200 }}{% endif %}"
          >
          <input
            type="hidden"
            name="price"
            value="{{ product.selected_or_first_available_variant.price | divided_by: 100.0 }}"
          >

          <div id="rq-step-input-{{ block_id }}">
            <div id="rq-dynamic-form-{{ block_id }}"></div>
          </div>
        </form>
      </div>
    </div>

    <div
      id="rq-step-success-{{ block_id }}"
      class="rq-success-screen"
      style="display: none; padding: 40px; text-align: center;"
    >
      <div class="rq-success-icon" style="margin-bottom: 24px;">
        <svg width="80" height="80" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle class="rq-success-icon-circle" cx="12" cy="12" r="10" stroke-width="2"/>
          <path class="rq-success-icon-check" d="M9 12l2 2 4-4" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>
      <h2 id="rq-success-title-{{ block_id }}" style="font-size: 28px; margin-bottom: 12px; color: var(--rq-text);">
        {{ config.successTitle | default: 'Quote Requested Successfully!' }}
      </h2>
      
      <div id="rq-success-variant-row-{{ block_id }}" style="display: none; margin-bottom: 8px;">
          <span style="color: #6d7175;">Product: </span>
          <span id="rq-success-product-{{ block_id }}" style="font-weight: 600; color: var(--rq-text);"></span>
          <span style="color: #6d7175; margin-left: 8px;">Variant: </span>
          <span id="rq-success-variant-{{ block_id }}" style="font-weight: 600; color: var(--rq-text);"></span>
      </div>

      <p
        id="rq-success-desc-{{ block_id }}"
        style="font-size: 16px; color: #6d7175; margin-bottom: 32px; max-width: 500px; margin-left: auto; margin-right: auto;"
      >
        {{
          config.successMessage
          | default: 'Thank you for your request. Our team will review your quote and get back to you shortly.'
        }}
      </p>
      <button
        type="button"
        onclick="rqResetAndClose('{{ block_id }}')"
        class="rq-submit-btn"
        style="width: auto; padding: 12px 32px;"
      >
        Continue Shopping
      </button>
    </div>
  </div>
</div>
