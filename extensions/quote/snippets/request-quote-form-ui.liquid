{%- assign block_id = block_id | default: 'global' -%}
<div id="rqModal-{{ block_id }}" class="rq-modal" aria-hidden="true" role="dialog">
  <div id="rq-app-root-{{ block_id }}" data-shop="{{ shop.permanent_domain }}" style="display:none;"></div>
  <div class="rq-modal-overlay" onclick="rqCloseModal('{{ block_id }}')"></div>
  <div class="rq-modal-content rq-full-page">
    <div class="rq-page-header">
      <div class="rq-header-content">
         <div class="rq-header-left">
            <h2 class="rq-page-title">Request a Quote</h2>
            <p class="rq-page-subtitle">Review your items and provide your details to receive a custom quote.</p>
         </div>
         <button class="rq-modal-close rq-close-page" onclick="window.rqCloseModal('{{ block_id }}')" aria-label="Close">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
            <span>Close</span>
         </button>
      </div>
    </div>

    <div class="rq-page-body">
      <div class="rq-page-left">
        <div class="rq-column-inner">
           <h3 class="rq-column-title">Your Items</h3>
           <div class="rq-product-hero">
              {% comment %} Product summary or Bulk items list injected here by JS {% endcomment %}
              <div class="rq-loading-summary">
                <div class="rq-spinner"></div>
                <p>Loading items...</p>
              </div>
           </div>
        </div>
      </div>

      <div class="rq-page-right">
        <form id="rq-form-{{ block_id }}" class="rq-quote-form-element" onsubmit="return false;">
          <div id="rq-step-form-{{ block_id }}">
            <h3 class="rq-column-title">Request Details</h3>
            <div id="rq-dynamic-form-{{ block_id }}">
              {% comment %} Dynamic fields injected here {% endcomment %}
            </div>
          </div>

          <div id="rq-step-success-{{ block_id }}" style="display: none;">
            <div class="rq-success-content">
              <div class="rq-success-icon">
                <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <h2>Quote Request Sent!</h2>
              <p>Thank you for your interest. Our team will review your request and get back to you shortly.</p>
              <button type="button" class="rq-btn rq-btn-secondary" onclick="window.rqResetAndClose('{{ block_id }}')">Return to Store</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>
</div>
